import numpy as np
import matplotlib.pyplot as plt
from scipy.io import wavfile
from scipy.signal import medfilt

# 1. HAZIRLIK VE SİNYAL OKUMA
# Ses dosyanın yolunu buraya yazılmalı. Ödev için içinde sessizlikler olan bir kayıt seç.
file_path = "alikocongoru.wav"

try:
    fs, signal = wavfile.read(file_path)
except FileNotFoundError:
    print(f"Hata: {file_path} bulunamadı. Lütfen dosya yolunu kontrol et.")
    # Test edebilmek için sahte bir sinyal oluşturuyoruz (Bunu gerçek dosyayla değiştir)
    fs = 16000
    t = np.linspace(0, 3, 3 * fs)
    signal = np.sin(2 * np.pi * 440 * t) + np.random.randn(len(t)) * 0.1

# Sinyal stereo ise mono yapalım
if len(signal.shape) > 1:
    signal = signal[:, 0]

# NORMALİZASYON: Sinyali [-1, 1] aralığına çekiyoruz
signal = signal / np.max(np.abs(signal))

# 2. PENCERELEME (FRAMING)
# ==========================================
frame_length_ms = 20  # 20 ms pencere boyutu
overlap_ms = 10  # 10 ms (%50) örtüşme

frame_length = int((frame_length_ms / 1000) * fs)
overlap = int((overlap_ms / 1000) * fs)
step = frame_length - overlap

num_frames = int(np.floor((len(signal) - frame_length) / step)) + 1

# Sızıntıyı (Leakage) önlemek için Hamming penceresi oluşturuyoruz
window_func = np.hamming(frame_length)

frames = []
for i in range(num_frames):
    start_idx = i * step
    end_idx = start_idx + frame_length
    # Pencereyi Hamming ile çarpıyoruz
    frame = signal[start_idx:end_idx] * window_func
    frames.append(frame)

frames = np.array(frames)


# 3. ENERJİ VE ZCR HESAPLAMA
# ==========================================
def calculate_energy(frame):
    """Karesel enerji hesaplama formülü"""
    return np.sum(frame ** 2)


def calculate_zcr(frame):
    """Sıfır Geçiş Oranı (Zero-Crossing Rate) hesaplama"""
    # İşaret değişimlerini sayar
    return np.sum(np.abs(np.diff(np.sign(frame)))) / (2 * len(frame))


energies = np.array([calculate_energy(f) for f in frames])
zcrs = np.array([calculate_zcr(f) for f in frames])

# 4. VAD (SES ETKİNLİĞİ ALGILAMA)
# ==========================================
# Dinamik gürültü eşiği: İlk 150 ms (yaklaşık 15 frame) gürültü kabul ediliyor
noise_frames = int((150 / 1000) * fs / step)
noise_energy_mean = np.mean(energies[:noise_frames])

# Gürültü eşiğine bir pay (margin) ekliyoruz
energy_threshold = max(noise_energy_mean * 5.0, 0.4)

# İlk Enerji Kararı
vad_decision = (energies > energy_threshold).astype(int)

# Önce ufak hataları temizlemek için medyan filtresi uygulayalım
vad_smoothed = medfilt(vad_decision, kernel_size=5)

# --- HANGOVER TIME (BEKLEME SÜRESİ) MANTIĞI ---
# Kelime sonlarındaki yutulmaları engellemek için eklendi.
hangover_limit = 15  # Yaklaşık 150 ms bekleme süresi (15 frame * 10ms step)
hangover_counter = 0

for i in range(len(vad_smoothed)):
    if vad_smoothed[i] == 1:
        # Eğer konuşma varsa, sayacı fulle
        hangover_counter = hangover_limit
    else:
        # Eğer enerji düştüyse (sessizlik başladıysa) ama sayaç henüz sıfırlanmadıysa
        if hangover_counter > 0:
            vad_smoothed[i] = 1  # Burayı zorla "Konuşma" yap (sessiz harfleri kurtar)
            hangover_counter -= 1


# 5. VOICED / UNVOICED SINIFLANDIRMASI
# ==========================================
# ZCR eşiğini tüm sinyalin ortalamasına göre veya sabit bir değere göre belirlenebilir.
zcr_threshold = np.mean(zcrs) + 0.05
# Yüksek enerji seviyesi için başka bir eşik
energy_high_threshold = np.mean(energies) * 0.5

voiced_decision = np.zeros(num_frames)
unvoiced_decision = np.zeros(num_frames)

for i in range(num_frames):
    if vad_smoothed[i] == 1:  # Sadece konuşma olan yerleri analiz eder
        # Voiced: Enerji YÜKSEK, ZCR DÜŞÜK
        if energies[i] > energy_high_threshold and zcrs[i] < zcr_threshold:
            voiced_decision[i] = 1
        # Unvoiced: ZCR YÜKSEK, Enerji Düşük/Orta
        else:
            unvoiced_decision[i] = 1


# 6. SADECE KONUŞMALARI BİRLEŞTİRİP KAYDETME
# ==========================================
speech_signal = []
for i in range(num_frames):
    if vad_smoothed[i] == 1:
        # Örtüşme kısımlarını basitçe uç uca ekliyoruz
        start_idx = i * step
        end_idx = start_idx + step  # Sadece step kadar olan kısmı al (örtüşme tekrarlarını önlemek için)
        speech_signal.extend(signal[start_idx:end_idx])

speech_signal = np.array(speech_signal)

# Sıkıştırma oranını raporla
original_duration = len(signal) / fs
compressed_duration = len(speech_signal) / fs
compression_ratio = ((original_duration - compressed_duration) / original_duration) * 100

print(f"Orijinal Süre: {original_duration:.2f} sn")
print(f"Kısaltılmış Süre: {compressed_duration:.2f} sn")
print(f"Elde Edilen Sıkıştırma (Boşluk Silme) Oranı: %{compression_ratio:.2f}")

wavfile.write("VAD_ciktisi.wav", fs, (speech_signal * 32767).astype(np.int16))  # 16-bit PCM formatında kaydet


# 7. GÖRSELLEŞTİRME (SUBPLOTLAR)
# ==========================================
# X eksenini saniye cinsine çevirme
time_signal = np.linspace(0, len(signal) / fs, len(signal))
time_frames = np.linspace(0, len(signal) / fs, num_frames)

plt.figure(figsize=(14, 10))

# 1. Orijinal Sinyal
plt.subplot(4, 1, 1)
plt.plot(time_signal, signal, color='gray', label="Orijinal Ses")
plt.title("Orijinal Ses Sinyali")
plt.ylabel("Genlik")
plt.grid(True, linestyle='--', alpha=0.5)

# 2. Karesel Enerji
plt.subplot(4, 1, 2)
plt.plot(time_frames, energies, color='blue', label="Karesel Enerji")
plt.axhline(y=energy_threshold, color='red', linestyle='--', label="Gürültü Eşiği")
plt.title("Pencere Bazlı Karesel Enerji")
plt.ylabel("Enerji")
plt.legend()
plt.grid(True, linestyle='--', alpha=0.5)

# 3. Zero-Crossing Rate (ZCR)
plt.subplot(4, 1, 3)
plt.plot(time_frames, zcrs, color='orange', label="ZCR")
plt.axhline(y=zcr_threshold, color='red', linestyle='--', label="ZCR Eşiği")
plt.title("Pencere Bazlı Sıfır Geçiş Oranı (ZCR)")
plt.ylabel("ZCR")
plt.legend()
plt.grid(True, linestyle='--', alpha=0.5)

# 4. VAD ve Voiced/Unvoiced Maskesi
plt.subplot(4, 1, 4)
plt.plot(time_signal, signal, color='lightgray', alpha=0.5)

# Maskeleri sinyal üzerine giydirme
for i in range(num_frames):
    start = time_frames[i]
    # Sona kadar boyaması için yaklaşık pencere süresi eklendi
    end = start + (frame_length_ms / 1000)

    if voiced_decision[i] == 1:
        plt.axvspan(start, end, color='green', alpha=0.3)  # Sesli Harfler (Yeşil)
    elif unvoiced_decision[i] == 1:
        plt.axvspan(start, end, color='yellow', alpha=0.3)  # Sessiz Harfler (Sarı)

# Custom legend için boş plotlar
plt.plot([], [], color='green', alpha=0.5, label='Voiced (Sesli)')
plt.plot([], [], color='yellow', alpha=0.5, label='Unvoiced (Sessiz)')
plt.title("VAD ve Voiced/Unvoiced Bölgeleri")
plt.xlabel("Zaman (sn)")
plt.ylabel("Genlik")
plt.legend(loc="upper right")

plt.tight_layout()
plt.show()
